# ╔═══════════════════════════════════════════════════════╗
# ║              nTV ENVIRONMENT CONFIGURATION            ║
# ╠═══════════════════════════════════════════════════════╣
# ║   Copy this file to .env and fill in your values.    ║
# ║   File loading order (later overrides earlier):       ║
# ║   1) .env.dev     (team defaults, shared)             ║
# ║   2) .env.staging (staging config, shared)            ║
# ║   3) .env.prod    (production config, shared)         ║
# ║   4) .env.secrets (production secrets, not shared)    ║
# ║   5) .env         (local overrides — highest priority)║
# ╚═══════════════════════════════════════════════════════╝

#####################################
# Core Identity
#####################################
NSELF_PROJECT_NAME=ntv
BASE_DOMAIN=local.nself.org
ENV=dev

#####################################
# Pro Plugin License
#####################################
# nTV requires the nTV bundle ($0.99/mo) for full media server features.
# Get a license at: https://nself.org/pricing
# After purchasing, activate with: nself license set <your-key>
#
# Free IPTV playback (M3U URLs) works without a license.
# The nTV bundle unlocks: transcoding, DVR, EPG scheduling, TMDB metadata,
# stream-gateway proxying, torrent management, and content acquisition.
#
NSELF_PLUGIN_LICENSE_KEY=nself_pro_your_key_here

#####################################
# Secrets — CHANGE ALL IN PRODUCTION
#####################################
HASURA_GRAPHQL_ADMIN_SECRET=change-me-in-production
HASURA_JWT_KEY=change-me-in-production-min-32-chars-required
AUTH_JWT_SECRET=change-me-in-production

#####################################
# PostgreSQL
#####################################
POSTGRES_DB=ntv_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres-dev-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_VERSION=16-alpine
POSTGRES_EXTENSIONS=uuid-ossp,pgcrypto,pg_trgm

#####################################
# Hasura GraphQL Engine
#####################################
HASURA_VERSION=v2.44.0
HASURA_JWT_TYPE=HS256
HASURA_GRAPHQL_ENABLE_CONSOLE=true
HASURA_GRAPHQL_DEV_MODE=true
HASURA_GRAPHQL_ENABLE_TELEMETRY=false
HASURA_GRAPHQL_CORS_DOMAIN=*
HASURA_ROUTE=api.${BASE_DOMAIN}

#####################################
# Auth
#####################################
AUTH_VERSION=0.36.0
AUTH_HOST=auth
AUTH_PORT=4000
AUTH_CLIENT_URL=http://localhost:3000
AUTH_ACCESS_TOKEN_EXPIRY=15m
AUTH_REFRESH_TOKEN_EXPIRY=7d
AUTH_WEBAUTHN_ENABLED=false
AUTH_ROUTE=auth.${BASE_DOMAIN}

# SMTP — dev uses Mailpit (included), swap for production provider
AUTH_SMTP_HOST=mailpit
AUTH_SMTP_PORT=1025
AUTH_SMTP_USER=
AUTH_SMTP_PASS=
AUTH_SMTP_SECURE=false
AUTH_SMTP_SENDER=noreply@${BASE_DOMAIN}

#####################################
# Nginx
#####################################
NGINX_DOMAIN=localhost
NGINX_VERSION=alpine
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
NGINX_CLIENT_MAX_BODY_SIZE=500M
NGINX_GZIP_ENABLED=true
SSL_MODE=local

#####################################
# Redis (session cache, stream state)
#####################################
REDIS_ENABLED=true
REDIS_VERSION=7-alpine
REDIS_PORT=6379
REDIS_PASSWORD=

#####################################
# MinIO (thumbnails, subtitles, EPG)
#####################################
MINIO_ENABLED=true
MINIO_VERSION=latest
MINIO_PORT=9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin-dev-password
MINIO_DEFAULT_BUCKETS=media,thumbnails,subtitles,epg,uploads
S3_ACCESS_KEY=storage-access-key-dev
S3_SECRET_KEY=storage-secret-key-dev
S3_BUCKET=media
S3_REGION=us-east-1
STORAGE_ROUTE=storage.${BASE_DOMAIN}

#####################################
# Mail
#####################################
MAILPIT_ENABLED=true
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025
MAILPIT_ROUTE=mail.${BASE_DOMAIN}

#####################################
# Search (MeiliSearch — media library)
#####################################
SEARCH_ENABLED=true
SEARCH_PROVIDER=meilisearch
MEILISEARCH_VERSION=v1.5
MEILISEARCH_PORT=7700
MEILI_ENV=development
MEILI_NO_ANALYTICS=true
SEARCH_API_KEY=
SEARCH_ROUTE=search.${BASE_DOMAIN}

#####################################
# nTV Bundle — Pro Plugin Config
#####################################
# These vars are consumed by the installed nTV plugins.
# Values are auto-generated at plugin install time for most fields.
# Only TMDB_API_KEY requires a manual value (free at themoviedb.org).

# TMDB metadata plugin — movie/TV posters, ratings, descriptions
TMDB_API_KEY=
TMDB_API_BASE_URL=https://api.themoviedb.org/3
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p
TMDB_LANGUAGE=en-US
TMDB_INCLUDE_ADULT=false

# media-processing plugin — transcoding and thumbnail generation
MEDIA_PROCESSING_TRANSCODE_ENABLED=true
MEDIA_PROCESSING_THUMBNAIL_ENABLED=true
MEDIA_PROCESSING_SUBTITLE_EXTRACTION=true
MEDIA_PROCESSING_OUTPUT_BUCKET=media
MEDIA_PROCESSING_THUMBNAIL_BUCKET=thumbnails
# MEDIA_PROCESSING_CONCURRENCY=2

# streaming plugin — HLS/DASH adaptive streaming
STREAMING_ENABLED=true
STREAMING_HLS_ENABLED=true
STREAMING_DASH_ENABLED=false
STREAMING_DVR_ENABLED=true
STREAMING_DVR_BUFFER_HOURS=4
STREAMING_ROUTE=stream.${BASE_DOMAIN}

# stream-gateway plugin — IPTV stream proxying and health monitoring
STREAM_GATEWAY_ENABLED=true
STREAM_GATEWAY_TIMEOUT_SECONDS=10
STREAM_GATEWAY_HEALTH_CHECK_INTERVAL=60
STREAM_GATEWAY_MAX_RETRIES=3
STREAM_GATEWAY_ROUTE=gateway.${BASE_DOMAIN}

# epg plugin — Electronic Programme Guide
EPG_ENABLED=true
EPG_REFRESH_INTERVAL_HOURS=12
EPG_STORAGE_BUCKET=epg
# EPG_SOURCE_URL=https://your-epg-source.com/guide.xml

# torrent-manager plugin (free) — torrent queue and ratio tracking
TORRENT_MANAGER_DOWNLOAD_DIR=/downloads
TORRENT_MANAGER_WATCH_DIR=/watch
TORRENT_MANAGER_MAX_ACTIVE=5
TORRENT_MANAGER_SEED_RATIO=2.0

# content-acquisition plugin (free) — library import and organization
CONTENT_ACQUISITION_LIBRARY_DIR=/library
CONTENT_ACQUISITION_AUTO_ORGANIZE=true
CONTENT_ACQUISITION_NAMING_FORMAT=plex

# subtitle-manager plugin (free) — subtitle search and sync
SUBTITLE_MANAGER_LANGUAGES=en
SUBTITLE_MANAGER_STORAGE_BUCKET=subtitles
# SUBTITLE_MANAGER_OPENSUBTITLES_API_KEY=

#####################################
# Frontend Connection (nTV Flutter app)
#####################################
# Set these in the nTV app Settings screen after the backend starts.
# NTV_BACKEND_URL=http://localhost:8080/v1/graphql
# NTV_AUTH_URL=http://localhost:4000
# NTV_STORAGE_URL=http://localhost:8080/v1/storage
