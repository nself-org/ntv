# nTV Environment Variables (copy to .env.local for local dev)

# Sentry DSN for error tracking and performance monitoring
# Get your DSN from https://sentry.io/settings/account/projects/
# Leave empty to disable Sentry
EXPO_PUBLIC_SENTRY_DSN=

# OpenTelemetry endpoint for distributed tracing
# Example: http://localhost:4318 (Jaeger/Zipkin)
# Leave empty to disable OTel
EXPO_PUBLIC_OTEL_ENDPOINT=
