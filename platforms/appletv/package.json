{
  "name": "ntv-appletv",
  "version": "1.2.0",
  "private": true,
  "scripts": {
    "start": "react-native start",
    "tvos": "react-native run-ios --scheme ntv-tvOS --destination 'Apple TV'",
    "androidtv": "react-native run-android --variant=tvRelease",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "jest --watchAll=false"
  },
  "dependencies": {
    "@nself/auth-core": "workspace:*",
    "@nself/graphql-client": "workspace:*",
    "@nself/i18n": "workspace:*",
    "@nself/observability": "workspace:*",
    "@nself/ui": "workspace:*",
    "react": "18.3.1",
    "react-native-tvos": "0.76.5-0"
  },
  "devDependencies": {
    "@react-native/eslint-config": "^0.76.0",
    "@react-native/metro-config": "^0.76.0",
    "@react-native/typescript-config": "^0.76.0",
    "@types/react": "^18.3.1",
    "@types/react-native": "^0.73.0",
    "eslint": "^8.57.0",
    "jest": "^29.6.3",
    "nativewind": "^4.1.23",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "react-native"
  }
}
