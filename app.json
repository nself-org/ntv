{
  "expo": {
    "name": "ɳTV",
    "slug": "ntv",
    "version": "1.2.0",
    "orientation": "default",
    "scheme": "ntv",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#030712"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "org.nself.ntv",
      "infoPlist": {
        "UIBackgroundModes": ["audio", "fetch"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#030712"
      },
      "package": "org.nself.ntv"
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "./src/app"
        }
      ],
      "expo-secure-store",
      [
        "react-native-video",
        {
          "enableNotificationControls": true
        }
      ],
      [
        "react-native-track-player",
        {
          "soundEngine": "default"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "router": {
      "origin": false
    }
  }
}
